# Theme
theme = Dark Pastel

# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Window padding (doubles as a purple border)
window-padding-x = 4
window-padding-y = 2
window-padding-color = extend

# Don't confirm when closing a pane
confirm-close-surface = false

# Silence bell
bell-features = no-attention,no-title

# Dim inactive splits
unfocused-split-opacity = 0.4

# Close pane
keybind = cmd+x=close_surface

# Split divider
split-divider-color = #6a0dad

# Open splits
keybind = cmd+shift+right=new_split:right
keybind = cmd+shift+left=new_split:left
keybind = cmd+shift+down=new_split:down
keybind = cmd+shift+up=new_split:up

# Project picker
keybind = cmd+p=text:\x10


# Navigate between splits
keybind = cmd+right=goto_split:right
keybind = cmd+left=goto_split:left
keybind = cmd+down=goto_split:down
keybind = cmd+up=goto_split:up
