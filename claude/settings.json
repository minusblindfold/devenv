{
  "env": {},
  "permissions": {
    "allow": [
      "Bash"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-activity.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-activity.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-activity.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-activity.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-context",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "devloop-marketplace": {
      "source": {
        "source": "directory",
        "path": "/Users/pacej/Documents/personal/devloop"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "devloop@devloop-marketplace": true
  }
}
