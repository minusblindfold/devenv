#!/usr/bin/env bash
set -euo pipefail

PLUGIN="dl@devloop-marketplace"
CACHE_DIR="$HOME/.claude/plugins/cache/devloop-marketplace/dl"

echo "Refreshing dl plugin..."

# Clear cache
if [ -d "$CACHE_DIR" ]; then
  rm -rf "$CACHE_DIR"
  echo "  Cleared cache: $CACHE_DIR"
else
  echo "  No cache to clear"
fi

# Pull latest marketplace repo
MARKETPLACE_DIR="$HOME/.claude/plugins/marketplaces/devloop-marketplace"
if [ -d "$MARKETPLACE_DIR" ]; then
  echo "  Pulling latest marketplace..."
  git -C "$MARKETPLACE_DIR" pull
else
  echo "  Marketplace repo not found: $MARKETPLACE_DIR" >&2
fi

# Reinstall
if command -v claude &>/dev/null; then
  if claude plugin install "$PLUGIN" 2>&1; then
    echo "  Plugin reinstalled"
  else
    echo "  Plugin install failed" >&2
    exit 1
  fi
else
  echo "  Claude Code not found" >&2
  exit 1
fi

echo ""
echo "Restart Claude Code to pick up changes."
