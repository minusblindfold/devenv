# Brewfile — managed by devenv
# Install everything: brew bundle

tap "oven-sh/bun"

brew "jq"         # JSON processing (used by bin/ scripts)
brew "fzf"        # Fuzzy finder (project picker, plan/design viewers)
brew "glow"       # Markdown renderer (cheat, view-plan, view-design, etc.)
brew "starship"   # Shell prompt
brew "gh"         # GitHub CLI
brew "shellcheck"  # Shell script linter
brew "shfmt"       # Shell script formatter
brew "oven-sh/bun/bun"  # JS runtime — used for: bunx ccusage@latest (Claude Code cost tracking)

cask "ghostty"                    # Terminal emulator
cask "claude-code"                # Claude Code CLI
cask "font-jetbrains-mono-nerd-font"  # Nerd font (icons in terminal)
